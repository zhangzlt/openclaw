{
  "skill": {
    "name": "agent-market-inspection",
    "version": "2.1.0",
    "kind": "script",
    "entry": "scripts/main.py",
    "entryShell": "scripts/entry.sh"
  },
  "runtime": {
    "language": "python",
    "minVersion": "3.11",
    "dependencies": {
      "pip": ["httpx", "playwright"],
      "system": ["agent-browser"],
      "optional": ["playwright install chromium"]
    },
    "timeout": {
      "default": 5400,
      "max": 7200
    }
  },
  "permissions": {
    "network": {
      "allowedHosts": [
        "agent.digitalchina.com",
        "bba12hub36.feishuapp.cn",
        "bba12hub36.aiforce.cloud",
        "aily.feishu.cn",
        "open.feishu.cn",
        "digitalchina.feishu.cn",
        "10.0.1.25",
        "10.0.1.27:8000",
        "10.0.5.86:9036",
        "10.0.5.86:9058"
      ],
      "allowLoopback": true
    },
    "filesystem": {
      "read": ["{baseDir}/../**", "{workspace}/work/agent-market/**"],
      "write": ["{workspace}/work/agent-market/reports/**", "{workspace}/work/agent-market/.auth/**"],
      "tempDir": true
    },
    "browser": {
      "enabled": true,
      "headless": true,
      "sandbox": false
    }
  },
  "envVars": [
    {
      "name": "CHAT_TEST",
      "required": true,
      "description": "设为 1 启用浏览器对话测试"
    },
    {
      "name": "CHAT_TEST_ALL",
      "required": true,
      "description": "设为 1 从市场第一个智能体开始全量测试"
    },
    {
      "name": "NON_CHAT_TEST",
      "required": true,
      "description": "设为 1 测试全部非对话智能体"
    },
    {
      "name": "CHAT_QUESTION_COUNT",
      "required": false,
      "description": "每日冒烟问题数，默认 1"
    },
    {
      "name": "CHAT_TEST_TIMEOUT",
      "required": false,
      "description": "单次等待回复秒数，默认 60"
    },
    {
      "name": "REPORT_RETENTION_DAYS",
      "required": false,
      "description": "运行产物保留天数，默认 7"
    },
    {
      "name": "AGENT_MARKET_USERNAME",
      "required": false,
      "description": "仅在人工登录态失效且允许自动登录时设置"
    },
    {
      "name": "AGENT_MARKET_PASSWORD",
      "required": false,
      "secret": true,
      "description": "禁止写入仓库，只能通过安全环境变量注入"
    },
    {
      "name": "LLM_API_KEY",
      "required": false,
      "secret": true,
      "description": "仅用于测试分析；每日通过状态不依赖 LLM"
    },
    {
      "name": "DAILY_SMOKE_ONLY",
      "required": false,
      "description": "默认 1，使用稳定问题便于跨日比较"
    }
  ],
  "sandbox": {
    "mode": "inherit",
    "recommended": false
  }
}